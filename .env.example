# =============================================================================
# Mẫu biến môi trường — copy thành `.env` ở thư mục gốc và điền giá trị thật.
#   copy .env.example .env
# Không commit file `.env` lên Git.
# JWT_SECRET và INTERNAL_API_SECRET phải GIỐNG NHAU ở vneid-auth và land-tax.
# =============================================================================

# --- MySQL (dùng chung) ---
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your-mysql-password

VNEID_DB_NAME=vneid
LANDTAX_DB_NAME=land-tax

# --- JWT & nội bộ (BẮT BUỘC trùng giữa 2 service Java) ---
JWT_SECRET=your-jwt-secret-min-32-chars
INTERNAL_API_SECRET=your-internal-api-secret

# --- vneid-auth: Gmail gửi OTP ---
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=your-gmail-app-password

# --- Firebase (tuỳ chọn) ---
FIREBASE_CONFIG_FILE=firebase-service-account.json

# --- land-tax: VNeID auth service ---
VNEID_SERVICE_URL=http://localhost:9090

# --- Cloudinary (upload tài liệu) ---
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# --- Gemini / AI chatbot ---
# AI_SECRET_KEY (land-tax) và API_SECRET_KEY (chatbot) phải CÙNG MỘT giá trị — tự đặt, không commit key thật lên Git
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_API_KEY=your-google-gemini-api-key
AI_SERVICE_URL=http://localhost:8000
AI_SECRET_KEY=your-chatbot-secret-key
API_SECRET_KEY=your-chatbot-secret-key

# --- PayOS (thanh toán) ---
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key
PAYOS_RETURN_URL=http://localhost:5173/payment/success
PAYOS_CANCEL_URL=http://localhost:5173/payment/cancel
PAYOS_RECEIVER_BANK_NAME=Ngân hàng MB Quân đội
PAYOS_RECEIVER_ACCOUNT_NAME=TEN CHU TAI KHOAN
PAYOS_RECEIVER_ACCOUNT_NUMBER=0000000000

# --- Upload legacy ---
UPLOAD_DIR=uploads
